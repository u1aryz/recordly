{
	"name": "recordly",
	"description": "A browser extension to select videos on a web page, capture them, and save as MP4",
	"private": true,
	"version": "0.1.0",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "https://github.com/u1aryz/recordly.git"
	},
	"homepage": "https://github.com/u1aryz/recordly",
	"keywords": [
		"browser-extension",
		"chrome-extension",
		"video-capture",
		"video-recorder",
		"mp4",
		"mediarecorder",
		"file-system-access",
		"wxt",
		"react"
	],
	"type": "module",
	"packageManager": "pnpm@11.6.0",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"prepare": "lefthook install",
		"dev": "wxt",
		"build": "wxt build",
		"zip": "wxt zip",
		"typecheck": "tsc --noEmit",
		"test": "vitest run",
		"test:e2e": "wxt build && playwright test",
		"demo:record": "wxt build && DEMO_VIDEO_DIR=e2e/demo/output playwright test -c playwright.demo.config.ts",
		"store:assets": "wxt build && STORE_ASSETS_DIR=docs/store playwright test -c playwright.store.config.ts",
		"format": "biome check --write --unsafe",
		"postinstall": "wxt prepare"
	},
	"dependencies": {
		"@heroicons/react": "^2.2.0",
		"@wxt-dev/webextension-polyfill": "^1.0.0",
		"daisyui": "^5.6.10",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"webextension-polyfill": "^0.12.0"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.2",
		"@commitlint/cli": "21.2.0",
		"@commitlint/config-conventional": "21.2.0",
		"@commitlint/types": "21.2.0",
		"@playwright/test": "^1.61.1",
		"@tailwindcss/vite": "4.3.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/node": "26.1.0",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"@wxt-dev/module-react": "1.2.2",
		"fake-indexeddb": "^6.2.5",
		"jsdom": "^29.1.1",
		"lefthook": "2.1.9",
		"tailwindcss": "4.3.2",
		"typescript": "6.0.3",
		"vitest": "^4.1.9",
		"wxt": "0.20.27"
	}
}
